{
  "name": "masking-worksheet",
  "private": true,
  "version": "1.0.24",
  "description": "Clinical Masking Simulator Desktop App",
  "author": {
    "name": "Author",
    "email": "author@example.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env NODE_ENV=development vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && electron-builder -p always"
  },
  "build": {
    "appId": "com.audiology.maskingsimulator",
    "productName": "Clinical Masking Simulator",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education",
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "public/vite.svg"
    },
    "linux": {
      "target": "deb",
      "category": "Education"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "isomorphic-git": "^1.38.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.1",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "electron-builder": {
      "app-builder-lib": {
        "@noble/hashes": "1.3.2"
      }
    }
  }
}